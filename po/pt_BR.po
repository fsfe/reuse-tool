#: src/reuse/_annotate.py:96
#, python-brace-format
msgid "Skipped unrecognised file '{path}'"
msgstr "Pulou o arquivo não reconhecido \"{path}\""

#: src/reuse/_annotate.py:102
#, python-brace-format
msgid "'{path}' is not recognised; creating '{path}.license'"
msgstr "\"{path}\" não foi reconhecido; criando \"{path}.license\""

#: src/reuse/_annotate.py:118
#, python-brace-format
msgid "Skipped file '{path}' already containing REUSE information"
msgstr "Pulou o arquivo \"{path}\" contendo informações de REUSE"

#: src/reuse/_annotate.py:148
#, python-brace-format
msgid "Error: Could not create comment for '{path}'"
msgstr "Erro: Não foi possível criar comentário para \"{path}\""

#: src/reuse/_annotate.py:155
#, python-brace-format
msgid ""
"Error: Generated comment header for '{path}' is missing copyright lines or "
"license expressions. The template is probably incorrect. Did not write new "
"header."
msgstr ""
"Erro: O cabeçalho de comentário gerado para \"{path}\" não contém linhas de "
"direitos autorais ou expressões de licença. O modelo provavelmente está "
"incorreto. Não foi possível escrever um novo cabeçalho."

#. TODO: This may need to be rephrased more elegantly.
#: src/reuse/_annotate.py:166
#, python-brace-format
msgid "Successfully changed header of {path}"
msgstr "Cabeçalho de {path} alterado com sucesso"

#: src/reuse/cli/annotate.py:67
msgid "Option '--copyright', '--license', or '--contributor' is required."
msgstr ""
"A opção \"--copyright\", \"--license\" ou \"--contributor\" é obrigatória."

#: src/reuse/cli/annotate.py:128
msgid ""
"The following files do not have a recognised file extension. Please use '--"
"style', '--force-dot-license', '--fallback-dot-license', or '--skip-"
"unrecognised':"
msgstr ""
"Os seguintes arquivos não possuem uma extensão reconhecida. Por favor, "
"utilize \"--style\", \"--force-dot-license\", \"--fallback-dot-license\" ou "
"\"--skip-unrecognised\":"

#: src/reuse/cli/annotate.py:161
#, python-brace-format
msgid ""
"'{path}' does not support single-line comments, please do not use '--single-"
"line'."
msgstr ""
"\"{path}\" não suporta comentários de linha única; por favor, não utilize "
"\"--single-line\"."

#: src/reuse/cli/annotate.py:168
#, python-brace-format
msgid ""
"'{path}' does not support multi-line comments, please do not use '--multi-"
"line'."
msgstr ""
"'{path}' não suporta comentários de múltiplas linhas; por favor, não utilize "
"\"--multi-line\"."

#: src/reuse/cli/annotate.py:214
#, python-brace-format
msgid "Template '{template}' could not be found."
msgstr "O modelo \"{template}\" não foi encontrado."

#: src/reuse/cli/annotate.py:237
#, python-brace-format
msgid "'{year}' is not a valid year range."
msgstr "\"{year}\" não é um intervalo de anos válido."

#: src/reuse/cli/annotate.py:246
#, python-brace-format
msgid ""
"Your operating system's year is set to '{year}'. This is not four digits, "
"and not supported."
msgstr ""
"O ano do seu sistema operacional está definido como \"{year}\". Isso não "
"corresponde a quatro dígitos e não é suportado."

#: src/reuse/cli/annotate.py:262
msgid "'--replace-license' and '--no-replace' cannot be used together."
msgstr ""

#: src/reuse/cli/annotate.py:301
msgid "Add copyright and licensing into the headers of files."
msgstr ""
"Adiciona informações de direitos autorais e licenças aos cabeçalhos dos "
"arquivos."

#: src/reuse/cli/annotate.py:304
msgid ""
"By using --copyright and --license, you can specify which copyright holders "
"and licenses to add to the headers of the given files."
msgstr ""
"Usando as opções --copyright e --license, você pode especificar quais "
"detentores de direitos autorais e licenças devem ser adicionados aos "
"cabeçalhos dos arquivos."

#: src/reuse/cli/annotate.py:310
msgid ""
"By using --contributor, you can specify people or entity that contributed "
"but are not copyright holder of the given files."
msgstr ""
"Ao usar --contributor, você pode especificar pessoas ou entidades que "
"contribuíram, mas não são detentoras dos direitos autorais dos arquivos em "
"questão."

#. TRANSLATORS: You may translate this. Please preserve capital letters.
#: src/reuse/cli/annotate.py:323
msgid "COPYRIGHT"
msgstr "DIREITO AUTORAL"

#: src/reuse/cli/annotate.py:326
msgid "Copyright holder, repeatable."
msgstr "detentor de direitos autorais, repetível."

#. TRANSLATORS: You may translate this. Please preserve capital letters.
#: src/reuse/cli/annotate.py:333
msgid "SPDX_IDENTIFIER"
msgstr "IDENTIFICADOR_SPDX"

#: src/reuse/cli/annotate.py:336
msgid "SPDX License Identifier, repeatable."
msgstr "Identificador de licença SPDX, repetível."

#. TRANSLATORS: You may translate this. Please preserve capital letters.
#: src/reuse/cli/annotate.py:342
msgid "CONTRIBUTOR"
msgstr "COLABORADOR"

#: src/reuse/cli/annotate.py:345
msgid "File contributor, repeatable."
msgstr "Colaborador de arquivos, repetível."

#. TRANSLATORS: You may translate this. Please preserve capital letters.
#: src/reuse/cli/annotate.py:352
msgid "YEAR"
msgstr "ANO"

#: src/reuse/cli/annotate.py:357
msgid ""
"Year of copyright notice. You may define multiple years or a range of years."
msgstr ""
"Ano do aviso de direito autoral. Você pode definir vários anos ou um "
"intervalo de anos."

#: src/reuse/cli/annotate.py:367
msgid "Comment style to use."
msgstr "Estilo de comentário para usar."

#: src/reuse/cli/annotate.py:377
msgid "Copyright prefix to use."
msgstr "Prefixo de direito autoral para usar."

#. TRANSLATORS: You may translate this. Please preserve capital letters.
#: src/reuse/cli/annotate.py:389
msgid "TEMPLATE"
msgstr "MODELO"

#: src/reuse/cli/annotate.py:391
msgid "Name of template to use."
msgstr "Nome do modelo para usar."

#: src/reuse/cli/annotate.py:398
msgid "Do not include year in copyright notice."
msgstr "Não inclui o ano no aviso de direito autoral."

#: src/reuse/cli/annotate.py:404
msgid "Merge copyright notices if they are identical except for their years."
msgstr ""
"Funde avisos de direitos autorais se eles forem idênticos, exceto por seus "
"anos."

#: src/reuse/cli/annotate.py:412
msgid "Force single-line comment style."
msgstr "Força estilo de comentário de uma única linha."

#: src/reuse/cli/annotate.py:419
msgid "Force multi-line comment style."
msgstr "Força estilo de comentário multilinha."

#: src/reuse/cli/annotate.py:425
msgid "Add headers to all files under specified directories recursively."
msgstr ""
"Adiciona cabeçalhos para todos os arquivos sob diretórios especificados de "
"forma recursiva."

#: src/reuse/cli/annotate.py:430
msgid "Do not replace the first header in the file; just add a new one."
msgstr ""
"Não substitui o primeiro cabeçalho no arquivo; apenas adiciona um novo."

#: src/reuse/cli/annotate.py:437
msgid "Always write a .license file instead of a header inside the file."
msgstr ""
"Sempre escreve um arquivo .license em vez de um cabeçalho dentro do arquivo."

#: src/reuse/cli/annotate.py:444
msgid "Write a .license file to files with unrecognised comment styles."
msgstr ""
"Escreve um arquivo .license em arquivos com estilos de comentário não "
"reconhecidos."

#: src/reuse/cli/annotate.py:451
msgid "Skip files with unrecognised comment styles."
msgstr "Pula arquivos com estilos de comentários não reconhecidos."

#: src/reuse/cli/annotate.py:462
msgid "Skip files that already contain REUSE information."
msgstr "Pula linhas que já contêm informações de REUSE."

#: src/reuse/cli/annotate.py:468
msgid "Replace existing SPDX-License-Identifiers, instead of adding onto them."
msgstr ""

#. TRANSLATORS: You may translate this. Please preserve capital letters.
#: src/reuse/cli/annotate.py:475
msgid "PATH"
msgstr "CAMINHO"

#: src/reuse/cli/annotate.py:534
#, python-brace-format
msgid "'{path}' is a binary, therefore using '{new_path}' for the header"
msgstr ""
"\"{path}\" é um binário; portanto, usando \"{new_path}\" para o cabeçalho"

#: src/reuse/cli/common.py:51
#, python-brace-format
msgid ""
"'{path}' could not be parsed. We received the following error message: "
"{message}"
msgstr ""
"\"{path}\" não pôde ser analisado. Recebemos a seguinte mensagem de erro: "
"{message}"

#: src/reuse/cli/common.py:87
#, python-brace-format
msgid "'{name}' is mutually exclusive with: {opts}"
msgstr "\"{name}\" é mutuamente exclusivo com: {opts}"

#: src/reuse/cli/common.py:103
msgid "'{}' is not a valid SPDX expression."
msgstr "\"{}\" não é uma expressão SPDX válida."

#: src/reuse/cli/convert_dep5.py:19
msgid ""
"Convert .reuse/dep5 into a REUSE.toml file. The generated file is placed in "
"the project root and is semantically identical. The .reuse/dep5 file is "
"subsequently deleted."
msgstr ""
"Converte .reuse/dep5 em um arquivo REUSE.toml. O arquivo gerado é colocado "
"na raiz do projeto e é semanticamente idêntico. O arquivo .reuse/dep5 é "
"posteriormente excluído."

#: src/reuse/cli/convert_dep5.py:31
msgid "No '.reuse/dep5' file."
msgstr "Arquivo \".reuse/dep5\" não encontrado."

#: src/reuse/cli/download.py:51
msgid "'{}' is not a valid SPDX License Identifier."
msgstr "\"{}\" não é um identificador de licença SPDX válido."

#: src/reuse/cli/download.py:58
msgid "Did you mean:"
msgstr "Você quis dizer:"

#: src/reuse/cli/download.py:65
msgid ""
"See <https://spdx.org/licenses/> for a list of valid SPDX License "
"Identifiers."
msgstr ""
"Consulte <https://spdx.org/licenses/> para obter uma lista de "
"identificadores de licença SPDX válidos."

#: src/reuse/cli/download.py:74
#, python-brace-format
msgid "Error: {spdx_identifier} already exists."
msgstr "Erro: {spdx_identifier} já existe."

#: src/reuse/cli/download.py:81
#, python-brace-format
msgid "Error: {path} does not exist."
msgstr "Erro: {path} não existe."

#: src/reuse/cli/download.py:85
msgid "Error: Failed to download license."
msgstr "Erro: Falha ao baixar a licença."

#: src/reuse/cli/download.py:90
msgid "Is your internet connection working?"
msgstr "Sua conexão com a internet está funcionando?"

#: src/reuse/cli/download.py:95
#, python-brace-format
msgid "Successfully downloaded {spdx_identifier}."
msgstr "Download da licença {spdx_identifier} realizado com sucesso."

#: src/reuse/cli/download.py:105
msgid "Download a license and place it in the LICENSES/ directory."
msgstr "Baixa uma licença e coloca-a no diretório LICENSES/."

#: src/reuse/cli/download.py:109
msgid ""
"LICENSE should be a valid SPDX License Identifier. You may specify LICENSE "
"multiple times to download multiple licenses."
msgstr ""
"LICENÇA deve ser um Identificador de Licença SPDX válido. Você pode "
"especificar LICENÇA várias vezes para baixar várias licenças."

#: src/reuse/cli/download.py:115
msgid ""
"If LICENSE starts with LicenseRef-, then a corresponding empty file is "
"created in the LICENSES/ directory."
msgstr ""
"Se LICENÇA começar com LicenseRef-, um arquivo vazio correspondente será "
"criado no diretório LICENSES/."

#: src/reuse/cli/download.py:128
msgid "Download all missing licenses detected in the project."
msgstr "Baixa todas as licenças ausentes detectadas no projeto."

#: src/reuse/cli/download.py:136
msgid "Path to download to."
msgstr "Caminho para baixar."

#: src/reuse/cli/download.py:142
msgid ""
"Source from which to copy license files; either a directory that contains "
"the file or the file itself."
msgstr ""
"Origem de onde copiar os arquivos de licença; um diretório que contenha o "
"arquivo ou o próprio arquivo."

#. TRANSLATORS: You may translate this. Please preserve capital letters.
#: src/reuse/cli/download.py:149
msgid "LICENSE"
msgstr "LICENÇA"

#: src/reuse/cli/download.py:165
msgid "The 'LICENSE' argument and '--all' option are mutually exclusive."
msgstr "O argumento \"LICENÇA\" e a opção \"--all\" são mutuamente exclusivos."

#: src/reuse/cli/download.py:177
msgid "Cannot use '--output' with more than one license."
msgstr "Não é possível usar \"--output\" com mais de uma licença."

#: src/reuse/cli/lint.py:28
#, python-brace-format
msgid ""
"Lint the project directory for REUSE compliance. This version of the tool "
"checks against version {reuse_version} of the REUSE Specification. You can "
"find the latest version of the specification at <https://reuse.software/spec/"
">."
msgstr ""
"Verifica a conformidade do diretório do projeto com a especificação REUSE. "
"Esta versão da ferramenta verifica a versão {reuse_version} da especificação "
"REUSE. Você pode encontrar a versão mais recente da especificação em "
"<https://reuse.software/spec/>."

#: src/reuse/cli/lint.py:34
msgid "Specifically, the following criteria are checked:"
msgstr "Especificamente, os seguintes critérios são verificados:"

#: src/reuse/cli/lint.py:38
msgid ""
"- Are there any bad (unrecognised, not compliant with SPDX) licenses in the "
"project?"
msgstr ""
"- Existem licenças inválidas (não reconhecidas, não compatíveis com SPDX) no "
"projeto?"

#: src/reuse/cli/lint.py:43
msgid "- Are there any deprecated licenses in the project?"
msgstr "- Existem licenças descontinuadas no projeto?"

#: src/reuse/cli/lint.py:47
msgid ""
"- Are there any license files in the LICENSES/ directory without file "
"extension?"
msgstr "- Existem arquivos de licença no diretório LICENSES/ sem extensão?"

#: src/reuse/cli/lint.py:54
msgid ""
"- Are any licenses referred to inside of the project, but not included in "
"the LICENSES/ directory?"
msgstr ""
"- Existem licenças referenciadas dentro do projeto, mas não incluídas no "
"diretório LICENSES/?"

#: src/reuse/cli/lint.py:61
msgid ""
"- Are any licenses included in the LICENSES/ directory that are not used "
"inside of the project?"
msgstr ""
"- Existem licenças incluídas no diretório LICENSES/ que não são utilizadas "
"no projeto?"

#: src/reuse/cli/lint.py:66
msgid "- Are there any read errors?"
msgstr "- Existem erros de leitura?"

#: src/reuse/cli/lint.py:69
msgid "- Do all files have valid copyright and licensing information?"
msgstr ""
"- Todos os arquivos possuem informações válidas de direitos autorais e "
"licenciamento?"

#: src/reuse/cli/lint.py:81 src/reuse/cli/lint_file.py:38
msgid "Prevent output."
msgstr "Evita gerar saída."

#: src/reuse/cli/lint.py:89 src/reuse/cli/supported_licenses.py:28
msgid "Format output as JSON."
msgstr "Formata a saída como JSON."

#: src/reuse/cli/lint.py:97
msgid "Format output as plain text. (default)"
msgstr "Formata a saída como texto simples. (padrão)"

#: src/reuse/cli/lint.py:105
msgid "Format output as errors per line."
msgstr "Formata a saída como um erro por linha."

#: src/reuse/cli/lint_file.py:25
msgid ""
"Lint individual files for REUSE compliance. The specified FILEs are checked "
"for the presence of copyright and licensing information, and whether the "
"found licenses are included in the LICENSES/ directory."
msgstr ""
"Verifica arquivos individuais para conformidade com REUSE. Os ARQUIVOs "
"especificados são verificados quanto à presença de informações de direitos "
"autorais e licenciamento, e se as licenças encontradas estão incluídas no "
"diretório LICENSES/."

#: src/reuse/cli/lint_file.py:46
msgid "Format output as errors per line. (default)"
msgstr "Formato de saída como um erro por linha. (padrão)"

#. TRANSLATORS: You may translate this. Please preserve capital letters.
#: src/reuse/cli/lint_file.py:51
msgid "FILE"
msgstr "ARQUIVO"

#: src/reuse/cli/lint_file.py:65
#, python-brace-format
msgid "'{file}' is not inside of '{root}'."
msgstr "\"{file}\" não está dentro de \"{root}\"."

#: src/reuse/cli/main.py:36
#: /root/.cache/pypoetry/virtualenvs/reuse-3tQ3zmSa-py3.13/lib/python3.13/site-packages/click/decorators.py:465
#, python-format
msgid "%(prog)s, version %(version)s"
msgstr "%(prog)s, versão %(version)s"

#: src/reuse/cli/main.py:39
msgid ""
"This program is free software: you can redistribute it and/or modify it "
"under the terms of the GNU General Public License as published by the Free "
"Software Foundation, either version 3 of the License, or (at your option) "
"any later version."
msgstr ""
"Este programa é um software livre: você pode redistribuí-lo e/ou modificá-lo "
"sob os termos da Licença Pública Geral GNU, como publicado pela Free "
"Software Foundation, ou versão 3 da Licença, ou (na sua opção) qualquer "
"versão posterior."

#: src/reuse/cli/main.py:46
msgid ""
"This program is distributed in the hope that it will be useful, but WITHOUT "
"ANY WARRANTY; without even the implied warranty of MERCHANTABILITY or "
"FITNESS FOR A PARTICULAR PURPOSE. See the GNU General Public License for "
"more details."
msgstr ""
"Este programa é distribuído na esperança de que ele seja útil, mas sem "
"qualquer garantia; sem sequer a garantia implícita de COMERCIALIZAÇÃO ou "
"ADEQUAÇÃO PARA UM PROPÓSITO ESPECÍFICO. Consulte a Licença Pública Geral GNU "
"para obter mais detalhes."

#: src/reuse/cli/main.py:53
msgid ""
"You should have received a copy of the GNU General Public License along with "
"this program. If not, see <https://www.gnu.org/licenses/>."
msgstr ""
"Você deve ter recebido uma cópia da Licença Pública Geral GNU junto com este "
"programa. Caso contrário, veja <https://www.gnu.org/licenses/>."

#: src/reuse/cli/main.py:61
msgid ""
"reuse is a tool for compliance with the REUSE recommendations. See <https://"
"reuse.software/> for more information, and <https://reuse.readthedocs.io/> "
"for the online documentation."
msgstr ""
"O reuse é uma ferramenta para conformidade com as recomendações REUSE. "
"Consulte <https://reuse.software/> para obter mais informações e <https://"
"reuse.readthedocs.io/> para a documentação online."

#: src/reuse/cli/main.py:68
msgid ""
"This version of reuse is compatible with version {} of the REUSE "
"Specification."
msgstr ""
"Esta versão do reuse é compatível com a versão {} da Especificação REUSE."

#: src/reuse/cli/main.py:72
msgid "Support the FSFE's work:"
msgstr "Apoie o trabalho da FSFE:"

#: src/reuse/cli/main.py:77
msgid ""
"Donations are critical to our strength and autonomy. They enable us to "
"continue working for Free Software wherever necessary. Please consider "
"making a donation at <https://fsfe.org/donate/>."
msgstr ""
"Doações são essenciais para nossa força e autonomia. Elas nos permitem "
"continuar trabalhando pelo Software Livre onde quer que seja necessário. "
"Considere fazer uma doação em <https://fsfe.org/donate/>."

#: src/reuse/cli/main.py:88
msgid "Enable debug statements."
msgstr "Habilita instruções de depuração."

#: src/reuse/cli/main.py:93
msgid "Hide deprecation warnings."
msgstr "Oculta avisos de descontinuidade."

#: src/reuse/cli/main.py:98
msgid "Do not skip over Git submodules."
msgstr "Não ignora os submódulos de Git."

#: src/reuse/cli/main.py:103
msgid "Do not skip over Meson subprojects."
msgstr "Não ignora os submódulos do Meson."

#: src/reuse/cli/main.py:108
msgid "Do not use multiprocessing."
msgstr "Não utiliza multiprocessamento."

#: src/reuse/cli/main.py:118
msgid "Define root of project."
msgstr "Define a raiz do projeto."

#: src/reuse/cli/spdx.py:22
msgid "Generate an SPDX bill of materials."
msgstr "Gera uma lista de materiais SPDX."

#: src/reuse/cli/spdx.py:32
msgid "File to write to."
msgstr "Arquivo para escrever."

#: src/reuse/cli/spdx.py:38
msgid ""
"Populate the LicenseConcluded field; note that reuse cannot guarantee that "
"the field is accurate."
msgstr ""
"Preenche o campo LicenseConcluded; observe que a reutilização não garante a "
"precisão do campo."

#: src/reuse/cli/spdx.py:50
msgid "Name of the person signing off on the SPDX report."
msgstr "Nome da pessoa signatária do relatório SPDX."

#: src/reuse/cli/spdx.py:54
msgid "Name of the organization signing off on the SPDX report."
msgstr "Nome da organização signatária do relatório SPDX."

#: src/reuse/cli/spdx.py:81
msgid ""
"'--creator-person' or '--creator-organization' is required when '--add-"
"license-concluded' is provided."
msgstr ""
"\"--creator-person\" ou \"--creator-organization\" é obrigatória quando \"--"
"add-license-concluded\" é fornecida."

#: src/reuse/cli/spdx.py:96
#, python-brace-format
msgid ""
"'{path}' does not match a common SPDX file pattern. Find the suggested "
"naming conventions here: https://spdx.github.io/spdx-spec/conformance/#44-"
"standard-data-format-requirements"
msgstr ""
"\"{path}\" não corresponde a um padrão de arquivo SPDX comum. Encontre as "
"convenções de nomenclatura sugeridas aqui: https://spdx.github.io/spdx-spec/"
"conformance/#44-standard-data-format-requirements"

#: src/reuse/cli/supported_licenses.py:19
msgid "List all licenses on the SPDX License List."
msgstr "Lista todas as licenças na Lista de Licenças SPDX."

#: src/reuse/extract.py:57
#, python-brace-format
msgid ""
"REUSE_ENCODING_MODULE must have a value in {modules}; it has '{env_module}'. "
"Aborting."
msgstr ""
"REUSE_ENCODING_MODULE deve ter um valor em {modules}; neste caso, o valor é "
"\"{env_module}\". Abortando."

#: src/reuse/extract.py:84
msgid ""
"No supported module that can detect the encoding of files could be "
"successfully imported. Re-read the installation instructions for the reuse "
"package, or try the following:"
msgstr ""
"Não foi possível importar com sucesso nenhum módulo compatível que possa "
"detectar a codificação de arquivos. Releia as instruções de instalação do "
"pacote reuse ou tente o seguinte:"

#: src/reuse/extract.py:90
msgid ""
"- If you are running a Linux distribution, try your equivalent of `apt "
"install file` or `dnf install file`."
msgstr ""
"- Se você estiver usando uma distribuição Linux, tente o equivalente a `apt "
"install arquivo` ou `dnf install arquivo`."

#: src/reuse/extract.py:95
msgid ""
"- Run ` pipx install reuse[charset-normalizer]`. Replace 'pipx' with 'pip' "
"if you are not using pipx."
msgstr ""
"- Execute `pipx install reuse[charset-normalizer]`. Substitua 'pipx' por "
"'pip' se você não estiver usando o pipx."

#: src/reuse/extract.py:489
#, python-brace-format
msgid ""
"'{path}' was detected as a binary file; not searching its contents for REUSE "
"information."
msgstr ""
"\"{path}\" foi detectado como um arquivo binário; não será possível "
"pesquisar informações de REUSE em seu conteúdo."

#: src/reuse/extract.py:500
#, python-brace-format
msgid ""
"extracting REUSE information from '{path}' (encoding {encoding}, encoding "
